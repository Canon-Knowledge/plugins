{
  "name": "knowledge-hub",
  "displayName": "Knowledge Hub",
  "version": "0.4.2",
  "description": "Guided onboarding for your Knowledge Hub wiki, per-session canon sync, conversational-agent feedback triage + fixes, and per-bot memory schema design.",
  "author": {
    "name": "Knowledge Hub",
    "url": "https://knowledgehub.com"
  },
  "homepage": "https://knowledgehub.com",
  "keywords": ["onboarding", "wiki", "knowledge-management"],
  "userConfig": {
    "api_base_url": {
      "type": "string",
      "title": "API base URL",
      "description": "Knowledge Hub SaaS API base. Use https://api.knowledgehub.com in production, or http://localhost:5173 for local dev."
    }
  },
  "mcpServers": {
    "knowledge-hub": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/server.js"],
      "env": {
        "KH_API_BASE_URL": "${user_config.api_base_url}"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/resume_onboarding.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/sync-canon.sh"
          }
        ]
      }
    ]
  }
}
